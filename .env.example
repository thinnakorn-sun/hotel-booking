# Copy values into backend/.env and frontend/.env.local (never commit real secrets).

# =============================================================================
# BACKEND — backend/.env
# =============================================================================

# HTTP port (Nest listens here)
PORT=3001

# Browser origins allowed to call the API (comma-separated for prod + previews).
# Example production:
#   CORS_ORIGIN=https://your-app.vercel.app,https://www.example.com
CORS_ORIGIN=http://localhost:3000

# PostgreSQL (Prisma). Example:
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
DATABASE_URL=

# Supabase project (server). URL can match the frontend project.
SUPABASE_URL=
# Optional alias if you already use the Next naming convention:
# NEXT_PUBLIC_SUPABASE_URL=

# Service role — keep only on the server; never in NEXT_PUBLIC_* or frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Used if you share one .env file with tooling that expects the anon key name:
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# =============================================================================
# FRONTEND — frontend/.env.local (or host env for `next build`)
# =============================================================================

# Public API base (no trailing slash). Required for browser requests.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional: placeholder when a suite has no image (defaults to picsum if unset).
NEXT_PUBLIC_SUITE_IMAGE_FALLBACK_URL=

# Admin login (Supabase Auth in the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
